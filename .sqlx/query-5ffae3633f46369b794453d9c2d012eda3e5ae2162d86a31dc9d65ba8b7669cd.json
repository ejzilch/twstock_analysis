  "query": "\n                SELECT symbol, name, exchange, data_source,\n                       COALESCE(earliest_ms, 0) AS \"earliest_ms!\",\n                       COALESCE(latest_ms, 0)   AS \"latest_ms!\",\n                       is_active, updated_at_ms\n                FROM symbols\n                WHERE is_active = $1 AND exchange = $2\n                ORDER BY symbol ASC\n                ",
