# 環境變數範本
#
# 使用方式:
#   cp env.example .env
#   填入實際數值後啟動服務
#
# 注意:
#   .env 已列入 .gitignore，禁止提交進 git
#   生產環境請使用強度足夠的隨機字串作為 API_KEY

# ── 環境設定 ──────────────────────────────────────────────────────────────────
# development: 啟用詳細 tracing log
# production:  關閉 debug log，啟用結構化 JSON log
APP_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# 格式: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://ai_bridge_user:password@localhost:5432/ai_bridge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API 認證 ──────────────────────────────────────────────────────────────────
# 前端使用者在設定頁輸入後存入 localStorage，對應 X-API-KEY header
# 生產環境請使用隨機產生的強密鑰，例如: openssl rand -hex 32
API_KEY=

# ── Python AI Service ─────────────────────────────────────────────────────────
# Rust Gateway 呼叫 Python AI Service 的內部位址
# 對應 ARCH_DESIGN.md 的 10s timeout 設定
PYTHON_AI_SERVICE_URL=http://localhost:8001

# ── FinMind API ───────────────────────────────────────────────────────────────
# 申請位置: https://finmindtrade.com/
# FINMIND_API_TIER 對應 RateLimitConfig::free() / paid()
# 升級付費方案後將 FINMIND_API_TIER 改為 paid，限流器自動放寬限額
FINMIND_API_TOKEN=
FINMIND_API_TIER=free

# ── Python AI Service 模型 ───────────────────────────────────────────────────
MODEL_VERSION=xgboost_v2.1
MODEL_PATH=./models/xgboost_v2.1.pkl

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_ 前綴的變數會打包進前端程式碼，不可放機敏資料
# 僅放 API 的公開 base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8089/api/v1
FRONTEND_URL=http://localhost:3000
